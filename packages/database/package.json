  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1"
  },
  "devDependencies": {
    "@nexusai/typescript-config": "workspace:*",
    "prisma": "^6.2.1",
    "typescript": "^5.7.3"
  }
