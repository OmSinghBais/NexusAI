# Application
NODE_ENV=development
APP_NAME=NexusAI

# API
API_HOST=0.0.0.0
API_PORT=3001

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://nexusai:nexusai@localhost:5432/nexusai?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://nexusai:nexusai@localhost:5672

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# AI Providers
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Vector DB
QDRANT_URL=http://localhost:6333
